# ─── Bootstrap variables (the ONLY runtime env vars the backend reads) ────────
# Everything else lives in the `app_config` MongoDB collection.
# See src/config/keys.ts for the full key catalog.

PORT=3000
MONGODB_URI=mongodb://localhost:27017/agoda-food

# NODE_ENV controls dev/prod behaviour (cors, static serving, OTP console log).
# Set to "production" in deployed environments.
# NODE_ENV=production

# ─── Managing config in the DB ────────────────────────────────────────────────
# All other settings (LINE, JWT, R2, Mailjet, etc.) are stored in the
# `app_config` collection and loaded once at startup. To add or change a value:
#
#   db.app_config.insertOne({
#     key: "JWT_SECRET",
#     value: "<long random string>",
#     isSecret: true,
#     description: "JWT session signing secret"
#   })
#
#   db.app_config.updateOne(
#     { key: "JWT_SECRET" },
#     { $set: { value: "<new value>" } }
#   )
#
# Required keys (server refuses to start if missing):
#   LINE_CHANNEL_ID, LINE_CHANNEL_SECRET, LINE_LOGIN_REDIRECT_URI,
#   JWT_SECRET, LIFF_ID
#
# All other keys are optional (have either a default in src/config/keys.ts
# or disable the related feature when absent).
