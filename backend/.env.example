PORT=3000
MONGODB_URI=mongodb://localhost:27017/agoda-food

# LINE Login channel credentials (from LINE Developers Console)
LINE_CHANNEL_ID=
LINE_CHANNEL_SECRET=

# Redirect URI registered on the LINE Login channel.
# Override to https://<your-heroku-app>.herokuapp.com/auth/line/callback in production.
LINE_LOGIN_REDIRECT_URI=http://localhost:5173/auth/line/callback

# JWT session signing
JWT_SECRET=change-me-to-a-long-random-string
JWT_EXPIRES_IN=7d

# LINE Messaging API (distinct from Login channel — used for push notifications)
LINE_MESSAGING_ACCESS_TOKEN=

# Restaurant referral verification
# Set to your company domain; any @agoda.com email will be accepted as a valid referrer
AGODA_EMAIL_DOMAIN=agoda.com

# OTP settings
OTP_TTL_MINUTES=10

# Cloudflare R2 (object storage for payment-proof screenshots)
# 1. Cloudflare dashboard → R2 → Create bucket (e.g. agoda-food-uploads)
# 2. R2 → Manage API Tokens → Create token with Object Read & Write on that bucket
# 3. Copy the values below. If left blank, the backend falls back to local
#    filesystem storage under <repo>/.uploads (NOT durable in production).
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=

# Legacy Stripe vars — no longer used by the BYO-PromptPay flow but kept here
# in case the Stripe path is reactivated later. Safe to leave blank.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
STRIPE_STATEMENT_DESCRIPTOR=AGODA FOOD
STRIPE_PROMPTPAY_QR_EXPIRY_MINUTES=3
